<?xml version="1.0" encoding="UTF-8"?>
<flow-definition plugin="workflow-job@2.46">
  <actions/>
  <description>Pipeline for DevOps CI Demo repository.</description>
  <keepDependencies>false</keepDependencies>
  <properties>
    <jenkins.branch.MetadataActionImpl plugin="branch-api@2.12.6"/>
  </properties>
  <definition class="org.jenkinsci.plugins.workflow.cps.CpsScmFlowDefinition" plugin="workflow-cps@2.1022">
    <scm class="hudson.plugins.git.GitSCM" plugin="git@4.16.1">
      <configVersion>2</configVersion>
      <userRemoteConfigs>
        <hudson.plugins.git.UserRemoteConfig>
          <url>https://github.com/&lt;your-user&gt;/devops-ci-demo.git</url>
          <branches>
            <hudson.plugins.git.BranchSpec>
              <name>*/main</name>
            </hudson.plugins.git.BranchSpec>
          </branches>
        </hudson.plugins.git.UserRemoteConfig>
      </userRemoteConfigs>
      <extensions/>
    </scm>
    <scriptPath>Jenkinsfile</scriptPath>
    <lightweight>true</lightweight>
  </definition>
  <triggers/>
  <disabled>false</disabled>
</flow-definition>
